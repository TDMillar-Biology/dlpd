import pandas as pd

configfile: "config/config.yaml"

samples = pd.read_csv(config["control_file"], sep="\t")

STRAINS = samples["strain"].tolist()

def get_reads(wildcards):
    return samples.loc[samples.strain == wildcards.strain, "reads"].values[0]

def get_assembly(wildcards):
    return samples.loc[samples.strain == wildcards.strain, "assembly"].values[0]

include: "rules/assembly.smk"

rule all:
    input:
        expand("results/{strain}/mummer/{strain}_r6_main.delta", strain=STRAINS),
        expand("results/{strain}/curated_assembly/{strain}.curated.fasta", strain=STRAINS)

